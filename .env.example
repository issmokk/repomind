# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# WARNING: Service role key bypasses RLS. Never expose to the browser.
# Needed by server-side indexing pipeline (split 01+).
SUPABASE_SERVICE_ROLE_KEY=

# GitHub OAuth (configured in Supabase Dashboard, not needed in env)
# GITHUB_CLIENT_ID and GITHUB_CLIENT_SECRET are set in Supabase Dashboard directly

# GitHub Personal Access Token (repo scope, for indexing)
GITHUB_PAT=
# GitHub App credentials (for installation-based auth and webhooks)
GITHUB_APP_ID=
# Base64-encoded PEM private key (avoids newline issues in env vars)
GITHUB_APP_PRIVATE_KEY=
# OAuth client credentials for the GitHub App
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# Secret for verifying webhook HMAC-SHA256 signatures
GITHUB_APP_WEBHOOK_SECRET=

# Embedding Providers (at least one required for indexing)
OLLAMA_BASE_URL=http://localhost:11434
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
COHERE_API_KEY=

# App URL (used for webhook URL generation; falls back to VERCEL_URL)
NEXT_PUBLIC_APP_URL=

# Inngest (auto-provisioned via Vercel Marketplace, optional for local dev server)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
